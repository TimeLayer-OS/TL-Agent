{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://timelayer-os.com/schemas/tl-agent/topology-v1.json",
  "title": "TL-Agent topology",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "topology_id",
    "nodes",
    "edges"
  ],
  "properties": {
    "topology_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string"
    },
    "mode": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "entry_action": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "action_id"
        ],
        "properties": {
          "action_id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "required_receipt_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required_receipts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "from",
          "to"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "condition": {
            "type": "string"
          }
        }
      }
    }
  }
}
